# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # PostgreSQL connection string (postgresql://user:pass@host:port/db)

# ── Supabase ───────────────────────────────────────────────────
VITE_SUPABASE_URL=        # Supabase project URL (frontend)
VITE_SUPABASE_ANON_KEY=   # Supabase anon/public key (frontend)
VITE_HERE_API_KEY=        # Here API Key (geocodificacao) - https://developer.here.com
SUPABASE_SERVICE_ROLE_KEY=# Supabase service_role key (backend only — never expose to frontend)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── WAHA WhatsApp API (LEGADO — substituído por Evolution) ──────
# ⚠️ SEGURANÇA: A WAHA NUNCA deve estar exposta diretamente na internet.
# 
# Arquitetura recomendada:
#   Navegador → Vercel (HTTPS) → API MandatoDigital → WAHA (localhost:8080 na VPS)
# 
# Porta 8080 deve estar BINDADA APENAS EM 127.0.0.1 na VPS:
#   docker run -d -p 127.0.0.1:8080:3000 ... devlikeapro/waha
# 
# NUNCA use:
#   -p 8080:3000  (expõe para 0.0.0.0 / internet)
# 
# URLs válidas:
#   Desenvolvimento local: http://localhost:8080
#   Produção (VPS):        http://localhost:8080  (backend fala com WAHA via localhost)
#   NUNCA:                 http://82.197.73.101:8080  (exposição direta insegura)
#
# Se precisar acessar de fora, use Cloudflare Tunnel ou VPN — nunca abra a porta.
WAHA_API_URL=             # WAHA API URL (ex: http://localhost:8080)
WAHA_API_KEY=             # WAHA API Key (backend only — never expose to frontend)

# ── Evolution WhatsApp API (NOVO) ───────────────────────────────
# Evolution API substitui a WAHA — engine Baileys, mais estável.
# Documentação: https://docs.evolutionfoundation.com.br
# Docker: evoapicloud/evolution-api:latest
#
# Mesma regra de segurança: bindar em localhost na VPS.
EVOLUTION_API_URL=        # Evolution API URL (ex: http://localhost:8080)
EVOLUTION_API_KEY=        # Evolution API Key (backend only — never expose to frontend)
EVOLUTION_INSTANCE_NAME=  # Nome da instância WhatsApp (default: "mandato")

# ── CNEFE API Proxy (VPS) ──────────────────────────────────────
CNEFE_DATABASE_URL=       # PostgreSQL local na VPS para dados CNEFE (nunca commitar)
CNEFE_API_URL=            # URL do proxy CNEFE (ex: http://localhost:4000)
